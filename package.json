{
  "name": "ember.nvp",
  "version": "0.2.3",
  "description": "ember project generator, alternative to the official blueprints, but more modern -- hopefully one day to upstream back in to ember-cli / official blueprints",
  "repository": {
    "type": "git",
    "url": "git@github.com:NullVoxPopuli/ember.nvp.git"
  },
  "type": "module",
  "imports": {
    "#args": "./src/cli/args.js",
    "#bases/*": "./src/bases/*/index.js",
    "#consolidators/*": "./src/consolidators/*",
    "#layers": "./src/layers/index.js",
    "#types": "./src/utils/types.ts",
    "#utils/*": "./src/utils/*",
    "#test-helpers": "./test/test-helpers.ts"
  },
  "exports": "./src/index.js",
  "bin": "./src/cli/index.js",
  "scripts": {
    "format": "prettier . --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:fix": "pnpm format",
    "lint:format": "prettier . --check",
    "lint:types": "tsc --noEmit",
    "new": "./test/manual.sh",
    "test:node": "FORCE_COLOR=1 vitest run --reporter=verbose --printConsoleTrace",
    "test:vitest": "FORCE_COLOR=1 vitest"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "babel-remove-types": "^2.0.0",
    "content-tag": "^4.2.0",
    "ember-apply": "^2.17.0",
    "execa": "^9.6.1",
    "latest-version": "^9.0.0",
    "package-name-regex": "^5.0.0"
  },
  "devDependencies": {
    "@ember/app-tsconfig": "^2.0.0",
    "@ember/library-tsconfig": "^2.0.0",
    "@glint/ember-tsc": "^1.7.5",
    "@glint/template": "^1.7.7",
    "@glint/tsserver-plugin": "^2.5.5",
    "concurrently": "^9.2.1",
    "ember-source": "^7.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-ember-template-tag": "^2.1.6",
    "release-plan": "^0.18.0",
    "rimraf": "^6.1.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">= 24"
  }
}
